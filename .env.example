# ==========================================================================
# paperless-ai (hb42 fork) — environment variable reference
# ==========================================================================
# Copy this file to data/.env and adjust the values you need. Values shown
# here are the defaults the code falls back to when an env var is unset.
#
# Most settings can also be edited in the GUI at /setup (first run) or
# /settings (later) — those write back to data/.env. The exceptions are
# documented inline.
# ==========================================================================

# --- Initial setup flag ---------------------------------------------------
# Set to 'yes' on first boot so the app shows the setup wizard. Once setup
# is complete the wizard re-routes to /dashboard automatically.
PAPERLESS_AI_INITIAL_SETUP=yes
PAPERLESS_AI_PORT=3000

# --- Paperless-NGX connection ---------------------------------------------
PAPERLESS_API_URL=http://localhost:8000/api
PAPERLESS_API_TOKEN=xxxxxxxxxxxxxxxxxxxx
PAPERLESS_USERNAME=clusterzx
# Fork addition — guards against silent deadlocks when Paperless-NGX is slow.
PAPERLESS_HTTP_TIMEOUT_MS=60000

# ==========================================================================
# Main pipeline AI provider
# ==========================================================================
# AI_PROVIDER selects the document-analysis provider. Supported values:
#   openai | ollama | custom | azure | anthropic
AI_PROVIDER=openai

# --- OpenAI ---------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Ollama (local LLM) ---------------------------------------------------
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Custom (any OpenAI-compatible endpoint, e.g. DeepSeek, Moonshot) -----
CUSTOM_API_KEY=
CUSTOM_BASE_URL=https://api.deepseek.com/v1
CUSTOM_MODEL=deepseek-chat

# --- Azure OpenAI ---------------------------------------------------------
AZURE_API_KEY=
AZURE_ENDPOINT=
AZURE_DEPLOYMENT_NAME=
AZURE_API_VERSION=2023-05-15

# --- Anthropic Claude (fork addition; AI_PROVIDER=anthropic) --------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# --- AI temperature -------------------------------------------------------
# Fix #927/#933 — Moonshot/Kimi reject the upstream-hardcoded 0.3.
# Set empty string to omit the parameter for providers that don't support it.
AI_TEMPERATURE=0.3

# ==========================================================================
# Document scan behaviour
# ==========================================================================
SCAN_INTERVAL=*/30 * * * *
DISABLE_AUTOMATIC_PROCESSING=no
PROCESS_PREDEFINED_DOCUMENTS=yes
PROCESS_ONLY_NEW_DOCUMENTS=yes
USE_EXISTING_DATA=no

# Token budgeting for the LLM call.
TOKEN_LIMIT=128000
RESPONSE_TOKENS=1000

# Tags that mark a document for processing (used when
# PROCESS_PREDEFINED_DOCUMENTS=yes).
TAGS=pre-process

# Mark every successfully analysed document with a tag.
ADD_AI_PROCESSED_TAG=no
AI_PROCESSED_TAG_NAME=ai-processed

# Pass an extra tag list to the LLM as a "hint" set.
USE_PROMPT_TAGS=no
PROMPT_TAGS=

# Custom fields the AI should extract (JSON object). The setup wizard
# populates this for you; here for completeness.
CUSTOM_FIELDS={"custom_fields":[]}

# --- Per-feature toggles --------------------------------------------------
# Switch individual AI outputs on/off without restarting the LLM call.
ACTIVATE_TAGGING=yes
ACTIVATE_CORRESPONDENTS=yes
ACTIVATE_DOCUMENT_TYPE=yes
ACTIVATE_TITLE=yes
ACTIVATE_CUSTOM_FIELDS=yes

# --- Restrict to existing taxonomy ---------------------------------------
# When 'yes', the LLM is told to only pick from the existing tag /
# correspondent / doc-type lists instead of inventing new ones.
RESTRICT_TO_EXISTING_TAGS=no
RESTRICT_TO_EXISTING_CORRESPONDENTS=no
RESTRICT_TO_EXISTING_DOCUMENT_TYPES=no

# --- Empty-tags retry (fork addition) ------------------------------------
# When the LLM returns tags:[], auto-retry with a correction prompt.
# Helps with conservative models like gpt-4o-mini. Set 'no' to disable.
AI_EMPTY_TAGS_RETRY=yes

# --- System prompt --------------------------------------------------------
# The base instruction handed to the LLM. The setup wizard ships a sane
# default; it is editable in /settings. Backticks + escaped \n keep the
# multi-line shape intact in env-var form.
SYSTEM_PROMPT=`You are a personalized document analyzer. Your task is to analyze documents and extract relevant information.\n\nAnalyze the document content and extract the following information into a structured JSON object:\n\n1. title: Create a concise, meaningful title for the document\n2. correspondent: Identify the sender/institution but do not include addresses\n3. tags: Select up to 4 relevant thematic tags\n4. document_date: Extract the document date (format: YYYY-MM-DD)\n5. language: Determine the document language (e.g. "de" or "en")\n      \nImportant rules for the analysis:\n\nFor tags:\n- FIRST check the existing tags before suggesting new ones\n- Use only relevant categories\n- Maximum 4 tags per document, less if sufficient (at least 1)\n- Avoid generic or too specific tags\n- Use only the most important information for tag creation\n- The output language is the one used in the document! IMPORTANT!\n\nFor the title:\n- Short and concise, NO ADDRESSES\n- Contains the most important identification features\n- For invoices/orders, mention invoice/order number if available\n- The output language is the one used in the document! IMPORTANT!\n\nFor the correspondent:\n- Identify the sender or institution\n  When generating the correspondent, always create the shortest possible form of the company name (e.g. "Amazon" instead of "Amazon EU SARL, German branch")\n\nFor the document date:\n- Extract the date of the document\n- Use the format YYYY-MM-DD\n- If multiple dates are present, use the most relevant one\n\nFor the language:\n- Determine the document language\n- Use language codes like "de" for German or "en" for English\n- If the language is not clear, use "und" as a placeholder
`

# ==========================================================================
# Security
# ==========================================================================
# REQUIRED — generate your own. `openssl rand -hex 32` is fine.
# Without a real secret, the optimizer's destructive endpoints are
# effectively unprotected.
JWT_SECRET=replace-with-64-hex-characters

# Optional: header `x-api-key` value for headless / programmatic access.
API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================================================
# RAG service (semantic chat over your documents)
# ==========================================================================
# Set to false to skip starting the Python service entirely (saves CPU/RAM
# if you don't use the /rag chat).
RAG_SERVICE_ENABLED=true
RAG_SERVICE_URL=http://localhost:8000

# ==========================================================================
# External API integration (fork addition)
# ==========================================================================
# Pull JSON from a third-party API and inject the (validated, truncated)
# data into the LLM prompt. Useful e.g. for vehicle registry lookups.
EXTERNAL_API_ENABLED=no
EXTERNAL_API_URL=
EXTERNAL_API_METHOD=GET
EXTERNAL_API_HEADERS={}
EXTERNAL_API_BODY={}
EXTERNAL_API_TIMEOUT=5000
EXTERNAL_API_TRANSFORM=

# ==========================================================================
# Entity Optimizer (fork addition)
# ==========================================================================
# The Optimizer can use a different LLM provider than the main pipeline.
# Leave OPTIMIZER_AI_PROVIDER empty to fall back to AI_PROVIDER.
# Per-provider model overrides take precedence over the main-pipeline model.
OPTIMIZER_AI_PROVIDER=
OPTIMIZER_OPENAI_MODEL=gpt-4o-mini
# OPTIMIZER_ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Gemini & Perplexity are Optimizer-only providers (not in the main pipeline).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
# OPTIMIZER_GEMINI_MODEL=gemini-1.5-pro
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar
# OPTIMIZER_PERPLEXITY_MODEL=sonar

# --- Optimizer Sync-Check -------------------------------------------------
# Periodic background analysis for duplicates. Writes pending suggestions
# to SQLite; the Optimizer sidebar badge shows the count.
OPTIMIZER_SYNC_ENABLED=yes
OPTIMIZER_SYNC_CRON=0 */12 * * *
# Run the sync check once ~60 s after container start (initial badge).
OPTIMIZER_SYNC_ON_START=no
