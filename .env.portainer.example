# ==========================================================================
# .env.portainer.example — Portainer / Docker stack template
# ==========================================================================
# Kopiere diese Datei nach /opt/stacks/paperless-ai/.env auf dem Docker-Host
# ODER trage die Werte im Portainer-Stack unter "Environment variables" direkt
# ein. Portainer liest automatisch aus einer .env neben dem Compose-File.
#
# Diese Datei deckt einen typischen Production-Setup ab. Für die vollständige
# Variablen-Referenz inkl. aller Optionen siehe .env.example.
# ==========================================================================

# --- Paperless-NGX Verbindung ---------------------------------------------
PAPERLESS_API_URL=http://192.168.0.X:PORT/api
PAPERLESS_API_TOKEN=dein-paperless-api-token-aus-paperless-settings
PAPERLESS_USERNAME=admin
# Schutz gegen Hänger wenn Paperless-NGX langsam antwortet
PAPERLESS_HTTP_TIMEOUT_MS=60000

# --- Hauptpipeline-Provider -----------------------------------------------
# Wähle einen: openai | ollama | custom | azure | anthropic
AI_PROVIDER=openai

# OpenAI (Standard)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude (Alternative für AI_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Ollama (lokales LLM, nur sinnvoll wenn ein Ollama-Container im selben Stack läuft)
# OLLAMA_API_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.2

# Custom (DeepSeek / Moonshot / jeder OpenAI-kompatible Endpoint)
# CUSTOM_API_KEY=
# CUSTOM_BASE_URL=https://api.deepseek.com/v1
# CUSTOM_MODEL=deepseek-chat

# Azure OpenAI
# AZURE_API_KEY=
# AZURE_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_DEPLOYMENT_NAME=
# AZURE_API_VERSION=2024-02-01

# Manche Provider (Moonshot/Kimi) lehnen den Default 0.3 ab — leere Zeichenkette
# = Parameter wird ausgelassen.
AI_TEMPERATURE=0.3

# --- Scan-Verhalten -------------------------------------------------------
SCAN_INTERVAL=*/30 * * * *
# Hard-Stopp für den Cron-Scan (Webhook /api/webhook/document funktioniert weiter)
DISABLE_AUTOMATIC_PROCESSING=no
TOKEN_LIMIT=128000
RESPONSE_TOKENS=1000

# AI-Features ein-/ausschalten ohne den LLM-Call zu sparen
ACTIVATE_TAGGING=yes
ACTIVATE_CORRESPONDENTS=yes
ACTIVATE_DOCUMENT_TYPE=yes
ACTIVATE_TITLE=yes
ACTIVATE_CUSTOM_FIELDS=yes

# Auf 'yes' wenn die LLM nur aus deiner existierenden Taxonomie wählen darf
RESTRICT_TO_EXISTING_TAGS=no
RESTRICT_TO_EXISTING_CORRESPONDENTS=no
RESTRICT_TO_EXISTING_DOCUMENT_TYPES=no

# --- Empty-tags retry -----------------------------------------------------
# Wenn das LLM tags:[] liefert, einmal mit Korrektur-Prompt nachfassen.
# Spart manuelle Korrekturen bei zögerlichen Modellen (gpt-4o-mini).
AI_EMPTY_TAGS_RETRY=yes

# --- Optimizer: eigener Provider (optional) -------------------------------
# Leer lassen, um den gleichen Provider wie die Hauptpipeline zu nutzen.
# Werte: openai | anthropic | gemini | perplexity | azure | ollama | custom
OPTIMIZER_AI_PROVIDER=
OPTIMIZER_OPENAI_MODEL=gpt-4o-mini

# Gemini / Perplexity sind nur via Optimizer nutzbar (nicht Hauptpipeline)
# GEMINI_API_KEY=...
# OPTIMIZER_GEMINI_MODEL=gemini-1.5-pro
# PERPLEXITY_API_KEY=pplx-...
# OPTIMIZER_PERPLEXITY_MODEL=sonar

# --- Optimizer Sync-Check -------------------------------------------------
# Periodischer Hintergrund-Scan für Duplikate. Schreibt Vorschläge in die DB,
# Sidebar-Badge zeigt die Anzahl offener Cluster.
OPTIMIZER_SYNC_ENABLED=yes
# Cron-Format. Default: alle 12 Stunden um 00:00 und 12:00
OPTIMIZER_SYNC_CRON=0 */12 * * *
# Bei Container-Start einmal nach ~60 s laufen lassen (initialer Badge)
OPTIMIZER_SYNC_ON_START=no

# --- RAG (semantische Suche) ----------------------------------------------
# Auf 'false' setzen um CPU/RAM zu sparen wenn der RAG-Chat nicht genutzt wird
RAG_SERVICE_ENABLED=true

# --- Sicherheit -----------------------------------------------------------
# PFLICHT: eigenes Secret erzeugen, z.B. mit: openssl rand -hex 32
# Ohne ordentliches Secret sind die destruktiven Optimizer-Endpoints offen.
JWT_SECRET=bitte-ersetzen-mit-64-zeichen-hex-string

# Optional: API-Key für headless Calls (Scheduler, Skripte)
# API_KEY=ein-langer-zufallsstring
